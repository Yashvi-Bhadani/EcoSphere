generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Connection URL moved to prisma.config.ts for Prisma v7+
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum DepartmentType {
  HR
  IT
  FINANCE
  OPERATIONS
  MARKETING
  SALES
  ENVIRONMENT
  MANAGEMENT
}

model User {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  email         String   @unique
  password      String
  role          Role     @default(EMPLOYEE)

  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])

  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Governance
  createdPolicies      Policy[]                 @relation("PolicyCreator")
  acknowledgements     PolicyAcknowledgement[]
  auditsConducted      Audit[]                  @relation("AuditCreator")
  reportedIssues       ComplianceIssue[]        @relation("IssueReporter")
  resolvedIssues       ComplianceIssue[]        @relation("IssueResolver")

  // Environment
  emissions            CarbonEmission[] @relation("CarbonEmissionCreator")
  energyConsumptions   EnergyConsumption[] @relation("EnergyConsumptionCreator")
  wasteRecords         WasteRecord[] @relation("WasteRecordCreator")
  environmentalGoals   EnvironmentalGoal[] @relation("EnvironmentalGoalCreator")
  createdEmissionCategories EmissionCategory[] @relation("EmissionCategoryCreator")
  createdEmissionFactors    EmissionFactor[]  @relation("EmissionFactorCreator")

  // Social
  volunteerActivities  VolunteerActivity[]
  rewards              Reward[]

  @@map("users")
}

model Department {
  id          String          @id @default(cuid())
  name        DepartmentType  @unique
  description String?

  users       User[]
  emissionCategories EmissionCategory[]
  emissionFactors    EmissionFactor[]
  carbonEmissions    CarbonEmission[]
  environmentalGoals EnvironmentalGoal[]
  wasteRecords       WasteRecord[]
  energyConsumptions EnergyConsumption[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("departments")
}

model EmissionCategory {
  id          String      @id @default(cuid())
  name        String
  code        String   @unique
  description String?

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  createdById String?
  createdBy   User?     @relation("EmissionCategoryCreator", fields: [createdById], references: [id])

  emissionFactors EmissionFactor[]
  carbonEmissions CarbonEmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("emission_categories")
}

model EmissionFactor {
  id               String      @id @default(cuid())
  name             String
  code             String   @unique
  description      String?
  activityType     String
  unit             String
  factorValue      Float
  factorUnit       String
  source           String?
  isActive         Boolean  @default(true)

  emissionCategoryId String
  emissionCategory   EmissionCategory @relation(fields: [emissionCategoryId], references: [id])

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  createdById String?
  createdBy   User? @relation("EmissionFactorCreator", fields: [createdById], references: [id])

  carbonEmissions CarbonEmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("emission_factors")
}

model CarbonEmission {
  id               String      @id @default(cuid())
  title            String
  activityName     String
  activityValue    Float
  activityUnit     String
  emissionAmount   Float
  scope            String?
  emissionDate     DateTime
  notes            String?
  source           String?

  emissionCategoryId String
  emissionCategory   EmissionCategory @relation(fields: [emissionCategoryId], references: [id])

  emissionFactorId String?
  emissionFactor   EmissionFactor? @relation(fields: [emissionFactorId], references: [id])

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  createdById String?
  createdBy   User? @relation("CarbonEmissionCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("carbon_emissions")
}

model EnvironmentalGoal {
  id           String      @id @default(cuid())
  title        String
  description  String?
  goalType     String?
  targetValue  Float
  currentValue Float?   @default(0)
  baselineValue Float?
  unit         String
  status       String   @default("ACTIVE")
  startDate    DateTime?
  targetDate   DateTime
  achievedAt   DateTime?

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  createdById String?
  createdBy   User? @relation("EnvironmentalGoalCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("environmental_goals")
}

model WasteRecord {
  id           String      @id @default(cuid())
  wasteType    String
  quantity     Float
  unit         String
  disposalMethod String
  hazardous    Boolean  @default(false)
  recycled     Boolean  @default(false)
  recordDate   DateTime @default(now())
  notes        String?

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  createdById String?
  createdBy   User? @relation("WasteRecordCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("waste_records")
}

model EnergyConsumption {
  id         String      @id @default(cuid())
  sourceType String
  consumption Float
  unit       String
  periodStart DateTime
  periodEnd   DateTime
  cost       Float?
  carbonEmission Float?
  notes      String?

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  createdById String?
  createdBy   User? @relation("EnergyConsumptionCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("energy_consumptions")
}

model Policy {
  id        String @id @default(cuid())
  title     String?
  creatorId String
  creator   User   @relation("PolicyCreator", fields: [creatorId], references: [id])
  acknowledgements PolicyAcknowledgement[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PolicyAcknowledgement {
  id       String @id @default(cuid())
  policyId String
  policy   Policy @relation(fields: [policyId], references: [id])
  userId   String
  user     User   @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Audit {
  id        String @id @default(cuid())
  title     String?
  creatorId String
  creator   User @relation("AuditCreator", fields: [creatorId], references: [id])
  createdAt DateTime @default(now())
}

model ComplianceIssue {
  id         String @id @default(cuid())
  title      String?
  reporterId String
  reporter   User @relation("IssueReporter", fields: [reporterId], references: [id])
  resolverId String?
  resolver   User? @relation("IssueResolver", fields: [resolverId], references: [id])
  createdAt DateTime @default(now())
}

model VolunteerActivity {
  id        String @id @default(cuid())
  title     String?
  createdById String?
  createdBy User? @relation(fields: [createdById], references: [id])
  createdAt DateTime @default(now())
}

model Reward {
  id        String @id @default(cuid())
  name      String?
  userId    String?
  user      User? @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
 
