generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum DepartmentType {
  HR
  IT
  FINANCE
  OPERATIONS
  MARKETING
  SALES
  ENVIRONMENT
  MANAGEMENT
}

model User {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  email         String   @unique
  password      String
  role          Role     @default(EMPLOYEE)

  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])

  isActive      Boolean  @default(true)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Governance
  createdPolicies      Policy[]                 @relation("PolicyCreator")
  acknowledgements     PolicyAcknowledgement[]
  auditsConducted      Audit[]                  @relation("AuditCreator")
  reportedIssues       ComplianceIssue[]        @relation("IssueReporter")
  resolvedIssues       ComplianceIssue[]        @relation("IssueResolver")

  // Environment
  emissions            CarbonEmission[]
  energyConsumptions   EnergyConsumption[]
  wasteRecords         WasteRecord[]
  environmentalGoals   EnvironmentalGoal[]

  // Social
  volunteerActivities  VolunteerActivity[]
  rewards              Reward[]

  @@map("users")
}

model Department {
  id          String          @id @default(cuid())
  name        DepartmentType  @unique
  description String?

  users       User[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("departments")
}